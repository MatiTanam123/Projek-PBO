('9780375508325', 'Cosmos', 150000.00, 'Sains', 10),
('9780385539258', 'A Little Life', 190000.00, 'Fiksi', 14),
('9780767905923', 'Tuesdays with Morrie: An Old Man, a Young Man, and Life''s Greatest Lesson', 210000.00, 'Non-Fiksi', 4),
